homomorphism:
maximum depth: 3

Apex(time,age,n,b):
    produce &(90)@o^(90)

Internode(time,age,n,b):
    component = generator.parameters["Internode"]
    with component.temporary_index(time,age,n,b):
        nmin = generator.InternodeNFirst()
        nmax = generator.InternodeNLast()
        nperiod = generator.InternodeNPeriod()
        if ((n < nmin
             or (nmax != -1 and n > nmax)
             or (((n - nmin) % nperiod) != 0))):
            produce [/(0)]
        bmin = generator.InternodeBFirst()
        bmax = generator.InternodeBLast()
        bperiod = generator.InternodeBPeriod()
        if ((b < bmin
             or (bmax != -1 and b > bmax)
             or (((b - bmin) % bperiod) != 0))):
            produce [/(0)]
        if generator.verbose_lpy:
            print(f"Homomorphism Internode[{age},{n}]")
        nproduce /(generator.InternodeRotationAngle(time,age,n,b))
        nproduce &(generator.InternodeAngle(time,age,n,b))
        nproduce SetColor(generator.InternodeColor(time,age,n,b))
        length = generator.InternodeLength(time,age,n,b)
        nproduce F(0.001 * length)
        xprev = 0.0
        for x in component.XIterator():
            DX = length * (x - xprev)
            xprev = x
            nproduce _(generator.InternodeWidth(time,age,n,b,x=x))
            nproduce &(generator.InternodeBend(time,age,n,b,x=x)*DX)
            nproduce /(generator.InternodeTwist(time,age,n,b,x=x)*DX)
            if x == 1:
                produce F(DX)
            else:
                nproduce F(DX)

