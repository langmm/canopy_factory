        produce *
    if age >= generator.BranchAgeRemove():
        if generator.verbose_lpy:
            print(f"Removing Branch[{age},{n}]")
        produce *
    elif (time + age) >= OUTPUT_TIME:
        produce Branch(time,age,n,b,w)
    elif age >= PLASTOCHRON and n < NMax:
        time = time + age
        if age >= PLASTOCHRON:        age = age - PLASTOCHRON
        if generator.verbose_lpy:
            print(f"Auxillary node: {n+1} (t = {time})")
        nproduce /(generator.BranchRotationAngle(time,age,n,b,w=w))
        nproduce &(generator.BranchAngle(time,age,n,b,w=w))
        nproduce @Ge @Gc Internode(time,age,n+1,b+1)
        nproduce [Node(time,age,n+1,b+1)]
    else:
        if generator.verbose_lpy:
            print(f"Ageing Branch[{age},{n}]")
        ageinc = min(generator.AgeInc(),
                     OUTPUT_TIME - (time + age))
        produce Branch(time,age+ageinc,n,b,w)

