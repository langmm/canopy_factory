Branch(time,age,n,b,w):
    nmin = generator.BranchNFirst()
    nmax = generator.BranchNLast()
    nperiod = generator.BranchNPeriod()
    if ((n < nmin
         or (nmax != -1 and n > nmax)
         or (((n - nmin) % nperiod) != 0))):
