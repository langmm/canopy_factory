        produce Internode(time,age+ageinc,n,b)

Node(time,age,n,b):
    for w in range(generator.CotyledonWMax()):
        nproduce [Cotyledon(time,age,n,b,w)]
    for w in range(generator.LeafWMax()):
        nproduce [Leaf(time,age,n,b,w)]
    for w in range(generator.BranchWMax()):
        nproduce [Branch(time,age,n,b,w)]
    for w in range(generator.FruitWMax()):
        nproduce [Fruit(time,age,n,b,w)]
    produce [/(0)]

