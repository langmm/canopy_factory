
############################################################
## External parameters
############################################################

extern(RUNTIME_PARAM = {})
extern(OUTPUT_TIME = 27)
extern(DERIVATION_LENGTH = OUTPUT_TIME)

############################################################
## Python functions
############################################################

from canopy_factory.utils import get_class_registry
generator_cls = get_class_registry().get("crop", "maize")
generator = generator_cls(context=context(), **RUNTIME_PARAM)
NMax = generator.NMax()
PLASTOCHRON = generator.Plastocron()
StartingAngle = generator.sample_dist("uniform", 0, 360)
if generator.verbose_lpy:
    print(f"OUTPUT_TIME = {OUTPUT_TIME}")
    print(f"DERIVATION_LENGTH = {DERIVATION_LENGTH}")
    print(f"PLASTOCHRON = {PLASTOCHRON}")


############################################################
## Begin LSystem syntax
############################################################

module A
module Apex
module Internode
module Node
module Leaf

Axiom: @Gc/(StartingAngle)Apex(0,0,0,0)@Ge
derivation length: DERIVATION_LENGTH

production:

Apex(time,age,n,b):
    nmin = generator.ApexNFirst()
    nmax = generator.ApexNLast()
    nperiod = generator.ApexNPeriod()
    if ((n < nmin
         or (nmax != -1 and n > nmax)
         or (((n - nmin) % nperiod) != 0))):
        print(f"Removing Apex[n={n}] P")
        produce *
    bmin = generator.ApexBFirst()
    bmax = generator.ApexBLast()
    bperiod = generator.ApexBPeriod()
    if ((b < bmin
         or (bmax != -1 and b > bmax)
         or (((b - bmin) % bperiod) != 0))):
        print(f"Removing Apex[b={b}] P")
        produce *
    if age >= generator.ApexAgeRemove():
        if generator.verbose_lpy:
            print(f"Removing Apex[{age},{n}]")
        produce *
    elif (time + age) >= OUTPUT_TIME:
        produce Apex(time,age,n,b)
    elif ((age >= PLASTOCHRON and n < NMax)
          or ((time + age) == 0 and n == 0)):
        time = time + age
        if age >= PLASTOCHRON:        age = age - PLASTOCHRON
        if generator.verbose_lpy:
            print(f"Node: {n} (t = {time})")
        nproduce @Ge @Gc Internode(time,age,n,b)
        nproduce [Node(time,age,n,b)]
        if generator.verbose_lpy:
            print(f"Next apex: {n + 1}")
        produce Apex(time,age,n+1,b)
    else:
        if generator.verbose_lpy:
            print(f"Ageing Apex[{age},{n}]")
        ageinc = min(generator.AgeInc(),
                     OUTPUT_TIME - (time + age))
        produce Apex(time,age+ageinc,n,b)

Internode(time,age,n,b):
    nmin = generator.InternodeNFirst()
    nmax = generator.InternodeNLast()
    nperiod = generator.InternodeNPeriod()
    if ((n < nmin
         or (nmax != -1 and n > nmax)
