homomorphism:
maximum depth: 3

Apex(time,age,n,b):
    produce &(90)@o^(90)

Internode(time,age,n,b):
    component = generator.parameters["Internode"]
    with component.temporary_index(time,age,n,b):
        nmin = generator.InternodeNFirst()
        nmax = generator.InternodeNLast()
        nperiod = generator.InternodeNPeriod()
        if ((n < nmin
             or (nmax != -1 and n > nmax)
             or (((n - nmin) % nperiod) != 0))):
            print(f"Removing Internode[n={n}]")
            produce [/(0)]
        bmin = generator.InternodeBFirst()
        bmax = generator.InternodeBLast()
        bperiod = generator.InternodeBPeriod()
        if ((b < bmin
             or (bmax != -1 and b > bmax)
             or (((b - bmin) % bperiod) != 0))):
            print(f"Removing Internode[b={b}]")
            produce [/(0)]
        if generator.verbose_lpy:
            print(f"Homomorphism Internode[{age},{n}]")
        nproduce SetColor(generator.InternodeColor(time,age,n,b))
        nproduce /(generator.InternodeRotationAngle(time,age,n,b))
        nproduce &(generator.InternodeAngle(time,age,n,b))
        length = generator.InternodeLength(time,age,n,b)
        nproduce F(0.001 * length)
        xprev = 0.0
        for x in component.XIterator():
            DX = length * (x - xprev)
            xprev = x
            nproduce _(generator.InternodeWidth(time,age,n,b,x=x))
            nproduce &(generator.InternodeBend(time,age,n,b,x=x)*DX)
            nproduce /(generator.InternodeTwist(time,age,n,b,x=x)*DX)
            if x == 1:
                produce F(DX)
            else:
                nproduce F(DX)

Leaf(time,age,n,b):
    component = generator.parameters["Leaf"]
    with component.temporary_index(time,age,n,b):
        nmin = generator.LeafNFirst()
        nmax = generator.LeafNLast()
        nperiod = generator.LeafNPeriod()
        if ((n < nmin
             or (nmax != -1 and n > nmax)
             or (((n - nmin) % nperiod) != 0))):
            print(f"Removing Leaf[n={n}]")
            produce [/(0)]
        bmin = generator.LeafBFirst()
        bmax = generator.LeafBLast()
        bperiod = generator.LeafBPeriod()
        if ((b < bmin
             or (bmax != -1 and b > bmax)
             or (((b - bmin) % bperiod) != 0))):
            print(f"Removing Leaf[b={b}]")
            produce [/(0)]
        if generator.verbose_lpy:
            print(f"Homomorphism Leaf[{age},{n}]")
        nproduce SetColor(generator.LeafColor(time,age,n,b))
        nproduce /(generator.LeafRotationAngle(time,age,n,b))
        nproduce &(generator.LeafAngle(time,age,n,b))
        nproduce SetContour(generator.LeafProfile(time,age,n,b,x=0))
        length = generator.LeafLength(time,age,n,b)
        nproduce F(0.001 * length)
        xprev = 0.0
        for x in component.XIterator():
            DX = length * (x - xprev)
            xprev = x
            nproduce _(generator.LeafWidth(time,age,n,b,x=x))
            nproduce &(generator.LeafBend(time,age,n,b,x=x)*DX)
            nproduce /(generator.LeafTwist(time,age,n,b,x=x)*DX)
            nproduce SetContour(generator.LeafProfile(time,age,n,b,x=x))
            if x == 1:
                produce F(DX)
            else:
                nproduce F(DX)

interpretation:

endlsystem
