        produce Internode(time,age+ageinc,n,b)

Node(time,age,n,b):
    for w in range(generator.LeafWMax()):
        nproduce [Leaf(time,age,n,b)]
    produce [/(0)]

Leaf(time,age,n,b):
    nmin = generator.LeafNFirst()
    nmax = generator.LeafNLast()
    nperiod = generator.LeafNPeriod()
    if ((n < nmin
         or (nmax != -1 and n > nmax)
         or (((n - nmin) % nperiod) != 0))):
        print(f"Removing Leaf[n={n}] P")
        produce *
    bmin = generator.LeafBFirst()
    bmax = generator.LeafBLast()
    bperiod = generator.LeafBPeriod()
    if ((b < bmin
         or (bmax != -1 and b > bmax)
         or (((b - bmin) % bperiod) != 0))):
