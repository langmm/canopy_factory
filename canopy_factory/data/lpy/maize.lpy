
############################################################
## External parameters
############################################################

extern(RUNTIME_PARAM = {})
extern(OUTPUT_TIME = 27)
extern(DERIVATION_LENGTH = OUTPUT_TIME)

############################################################
## Python functions
############################################################

from canopy_factory.utils import get_class_registry
generator_cls = get_class_registry().get("crop", "maize")
generator = generator_cls(context=context(), **RUNTIME_PARAM)
NMax = generator.NMax()
PLASTOCHRON = generator.Plastocron()
StartingAngle = generator.sample_dist("uniform", 0, 360)
if generator.verbose_lpy:
    print(f"OUTPUT_TIME = {OUTPUT_TIME}")
    print(f"DERIVATION_LENGTH = {DERIVATION_LENGTH}")
    print(f"PLASTOCHRON = {PLASTOCHRON}")


############################################################
## Begin LSystem syntax
############################################################

module A
module Apex
module Leaf
module Internode
module Node

Axiom: @Gc/(StartingAngle)Apex(0,0,0)@Ge
derivation length: DERIVATION_LENGTH

production:

Apex(time,age,n):
    if age >= generator.ApexAgeRemove():
        if generator.verbose_lpy:
            print(f"Removing Apex[{age},{n}]")
        produce *
    elif (time + age) >= OUTPUT_TIME:
        produce Apex(time,age,n)
    elif ((age >= PLASTOCHRON and n < NMax)
          or ((time + age) == 0 and n == 0)):
        time = time + age
        if age >= PLASTOCHRON:        age = age - PLASTOCHRON
        if generator.verbose_lpy:
            print(f"Node: {n} (t = {time})")
        nproduce @Ge @Gc Internode(time,age,n)
        nproduce [Node(time,age,n)]
        if generator.verbose_lpy:
            print(f"Next apex: {n + 1}")
        produce Apex(time,age,n+1)
    else:
        if generator.verbose_lpy:
            print(f"Ageing Apex[{age},{n}]")
        ageinc = min(generator.AgeInc(),
                     OUTPUT_TIME - (time + age))
        produce Apex(time,age+ageinc,n)

Leaf(time,age,n):
    if age >= generator.LeafAgeRemove():
        if generator.verbose_lpy:
            print(f"Removing Leaf[{age},{n}]")
        produce *
    elif (time + age) >= OUTPUT_TIME:
        produce Leaf(time,age,n)
    else:
        if generator.verbose_lpy:
            print(f"Ageing Leaf[{age},{n}]")
        ageinc = min(generator.AgeInc(),
                     OUTPUT_TIME - (time + age))
        produce Leaf(time,age+ageinc,n)

Internode(time,age,n):
    if age >= generator.InternodeAgeRemove():
        if generator.verbose_lpy:
            print(f"Removing Internode[{age},{n}]")
        produce *
    elif (time + age) >= OUTPUT_TIME:
        produce Internode(time,age,n)
    else:
        if generator.verbose_lpy:
            print(f"Ageing Internode[{age},{n}]")
        ageinc = min(generator.AgeInc(),
                     OUTPUT_TIME - (time + age))
        produce Internode(time,age+ageinc,n)

Node(time,age,n):
    for w in range(generator.LeafWMax() - 1):
        nproduce [Leaf(time,age,n)]
    w = generator.LeafWMax() - 1
    produce [Leaf(time,age,n)]

homomorphism:
maximum depth: 3

Apex(time,age,n):
    produce &(90)@o^(90)

Leaf(time,age,n):
    component = generator.parameters["Leaf"]
    with component.temporary_index(time,age,n):
        if generator.verbose_lpy:
            print(f"Homomorphism Leaf[{age},{n}]")
        nproduce SetColor(generator.LeafColor(time,age,n))
        nproduce /(generator.LeafRotationAngle(time,age,n))
        nproduce &(generator.LeafAngle(time,age,n))
        nproduce SetContour(generator.LeafProfile(time,age,n,x=0))
        length = generator.LeafLength(time,age,n)
        nproduce F(0.001 * length)
        xprev = 0.0
        for x in component.XIterator():
            DX = length * (x - xprev)
            xprev = x
            nproduce _(generator.LeafWidth(time,age,n,x=x))
            nproduce &(generator.LeafBend(time,age,n,x=x)*DX)
            nproduce /(generator.LeafTwist(time,age,n,x=x)*DX)
            nproduce SetContour(generator.LeafProfile(time,age,n,x=x))
            if x == 1:
                produce F(DX)
            else:
                nproduce F(DX)

Internode(time,age,n):
    component = generator.parameters["Internode"]
    with component.temporary_index(time,age,n):
        if generator.verbose_lpy:
            print(f"Homomorphism Internode[{age},{n}]")
        nproduce SetColor(generator.InternodeColor(time,age,n))
        nproduce /(generator.InternodeRotationAngle(time,age,n))
        nproduce &(generator.InternodeAngle(time,age,n))
        length = generator.InternodeLength(time,age,n)
        nproduce F(0.001 * length)
        xprev = 0.0
        for x in component.XIterator():
            DX = length * (x - xprev)
            xprev = x
            nproduce _(generator.InternodeWidth(time,age,n,x=x))
            nproduce &(generator.InternodeBend(time,age,n,x=x)*DX)
            nproduce /(generator.InternodeTwist(time,age,n,x=x)*DX)
            if x == 1:
                produce F(DX)
            else:
                nproduce F(DX)

interpretation:

endlsystem
